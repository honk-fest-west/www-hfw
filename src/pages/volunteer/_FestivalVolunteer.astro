---
import Title from "@components/Title.astro";
---

<div class="content-container">
  <Title title="Festival Volunteer" center={true} />
  <p class="content">
    We need all the help we can get. Please sign up below and join an amazing
    group of people that help run HONK! Fest West every year.
  </p>
  <a
    href={'https://m.signupgenius.com/#!/showSignUp/30E044EAAA82FA1FD0-63587260-honk?useFullSite=false'}
    class="text-button-shadow block font-base font-medium text-center rounded antialiased text-button-text flex-none mt-3 bg-button-secondary w-full text-lg bg-opacity-80 px-2 hover:bg-opacity-90"
  >
    » SIGN UP HERE
  </a>
</div>
